SEARXNG_URL=http://127.0.0.1:8080/search
SCRAPE_URL=http://192.168.1.81:5678/webhook/scrape-url

# LangGraph gateway. Do not point this to Ollama.
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=onyx-fast
LLM_API_KEY=local-dummy-key

DEFAULT_MAX_RESULTS=1
MAX_RESULTS_HARD=2

DEFAULT_MAX_CHARS_PER_PAGE=2500
MAX_CHARS_PER_PAGE_HARD=5000
MAX_TOTAL_CONTEXT_CHARS=6000

LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

SEARCH_TIMEOUT_SECONDS=15
SCRAPE_TIMEOUT_SECONDS=25
LLM_TIMEOUT_SECONDS=60

MAX_CONCURRENT_RESEARCH=1
LOG_LEVEL=INFO
